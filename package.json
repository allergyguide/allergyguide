{
	"name": "allergyguide",
	"version": "0.8.0",
	"description": "allergyguide build",
	"author": "Joshua Yu <allergyguideca@gmail.com>",
	"license": "GPL-3.0",
	"homepage": "https://allergyguide.ca",
	"scripts": {
		"abridge": "node package_abridge.js",
		"offline": "npm run abridge -- offline",
		"elasticlunrjava": "npm run abridge -- elasticlunrjava",
		"elasticlunr": "npm run abridge -- elasticlunr",
		"pagefind": "npm run abridge -- pagefind",
		"tinysearch": "npm run abridge -- tinysearch",
		"test": "vitest run",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"check:ts": "tsc --noEmit",
		"check": "npm run lint && npm run check:ts",
		"build:core": "tsx scripts/build-fetch-secure-assets.mts && npm run check && tsx scripts/build.mts",
		"serve": "npm i && npm run build:core && zola build && vitest run && netlify dev",
		"build": "npm run build:core && npm run abridge --"
	},
	"dependencies": {
		"@netlify/functions": "^5.1.2",
		"@supabase/supabase-js": "^2.90.1",
		"bcryptjs": "^3.0.3",
		"cookie": "^1.1.1",
		"decimal.js": "^10.6.0",
		"dotenv": "^17.2.3",
		"fast-toml": "^0.5.4",
		"fuzzysort": "^3.1.0",
		"jsonminify": "^0.4.2",
		"jsonwebtoken": "^9.0.3",
		"jspdf": "^4.0.0",
		"jspdf-autotable": "^5.0.2",
		"lit-html": "^3.3.2",
		"pagefind": "^1.1.0",
		"pako": "^2.1.0",
		"pdf-lib": "^1.17.1",
		"qrcode": "^1.5.4",
		"replace-in-file": "^8.1.0",
		"resend": "^6.12.4",
		"uglify-js": "^3.17.4",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bcryptjs": "^2.4.6",
		"@types/cloudflare-turnstile": "^0.2.2",
		"@types/node": "^22.0.0",
		"@types/qrcode": "^1.5.6",
		"esbuild": "^0.27.0",
		"jsdom": "^27.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.14"
	},
	"engines": {
		"node": "22.x"
	}
}
